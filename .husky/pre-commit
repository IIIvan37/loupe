#!/bin/sh

# Node from .nvmrc + pnpm via Corepack (on WSL node isn't always on PATH).
if [ -z "$NVM_DIR" ]; then
  export NVM_DIR="$HOME/.nvm"
fi
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
  nvm use >/dev/null 2>&1 || true
fi
if ! command -v pnpm >/dev/null 2>&1 && command -v corepack >/dev/null 2>&1; then
  corepack enable >/dev/null 2>&1 || true
fi

# Staged files (added/copied/modified/renamed — deletions need no formatting).
staged=$(git diff --cached --name-only --diff-filter=ACMR)

# Doc-only fast path: a commit touching only *.md / docs/** skips the code gate
# — but NOT the docs fitness function (docs/docs.spec.ts, once it exists): the
# STATUS/session bounds exist precisely to catch doc commits, so exempting doc
# commits from them would hollow out the guard. commitlint still runs via the
# commit-msg hook; CI re-runs the full gate.
if [ -n "$staged" ] && ! printf '%s\n' "$staged" | grep -qvE '\.md$|^docs/'; then
  echo "📝 doc-only commit — skipping the code gate"
  if [ -f docs/docs.spec.ts ]; then
    echo "📝 running the docs fitness function"
    pnpm -s exec vitest run docs/docs.spec.ts
  fi
  exit 0
fi

# Format the staged files — but ONLY those with no unstaged edits. Formatting a
# partially staged file and re-adding it would sweep the unstaged hunks into the
# commit (`git add <path>` stages the whole working-tree content), silently
# destroying a careful `git add -p`. Those files are left untouched with a loud
# warning instead; the repo-wide `biome check` in CI is the backstop. (This is
# consistent with the rest of the hook: typecheck & tests read the working tree,
# not the index, so pre-commit was never a faithful index check.)
if [ -n "$staged" ]; then
  unstaged=$(git diff --name-only)
  fully_staged=""
  partially_staged=""
  for f in $staged; do
    if printf '%s\n' "$unstaged" | grep -qxF "$f"; then
      partially_staged="$partially_staged $f"
    else
      fully_staged="$fully_staged $f"
    fi
  done

  if [ -n "$fully_staged" ]; then
    echo "🔍 biome --write (fully staged files)"
    printf '%s\n' $fully_staged | xargs pnpm -s exec biome check --write --no-errors-on-unmatched
    printf '%s\n' $fully_staged | xargs git add --
  fi

  if [ -n "$partially_staged" ]; then
    echo "⚠️  partially staged (unstaged edits too) — NOT auto-formatted, to protect"
    echo "   your staged hunks. CI's repo-wide biome check is the backstop:"
    for f in $partially_staged; do echo "   - $f"; done
  fi
fi

# Blocking guardrails (greenfield: no debt, so no tolerance). Same composition
# as `pnpm gate` — a commit that passes here cannot fail CI on a skipped check.
# (Only repo-wide `biome check` is replaced by the staged-only pass above, so a
# partial commit isn't blocked by unformatted WIP files; CI covers the rest.)
echo "🔍 gate (typecheck + arch + design + react + coverage + knip + jscpd)"
pnpm -s typecheck
pnpm -s check:arch
pnpm -s check:design
pnpm -s check:react
pnpm -s test:coverage
pnpm -s check:dead
pnpm -s check:dup

echo "✅ Pre-commit OK"
