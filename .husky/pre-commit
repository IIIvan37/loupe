#!/bin/sh

# Node from .nvmrc + pnpm via Corepack (on WSL node isn't always on PATH).
if [ -z "$NVM_DIR" ]; then
  export NVM_DIR="$HOME/.nvm"
fi
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
  nvm use >/dev/null 2>&1 || true
fi
if ! command -v pnpm >/dev/null 2>&1 && command -v corepack >/dev/null 2>&1; then
  corepack enable >/dev/null 2>&1 || true
fi

# Blocking guardrails (greenfield: no debt, so no tolerance).
echo "🔍 biome --write"
pnpm -s check:fix
git add -u

echo "🔍 gate (typecheck + check:arch + tests + knip + jscpd)"
pnpm -s typecheck
pnpm -s check:arch
pnpm -s test
pnpm -s check:dead
pnpm -s check:dup

echo "✅ Pre-commit OK"
